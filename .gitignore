# Root Gitignore for AI Trip Planner Workspace

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.bak
*.iml

# OS files
.DS_Store
Thumbs.db

# Dependencies and Build Artifacts
node_modules/
build/
dist/
.dart_tool/
.pub-cache/
.flutter-plugins
.flutter-plugins-dependencies

# Environment and Secrets
.env
.env.backup
.env.local
.env.development.local
.env.test.local
.env.production.local
*.key
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# Local/Temporary
tmp/
Cortex/
.gemini/
analyze_out.txt
package-lock.json
composer.lock

# Laravel Specific (Root level oversight)
/aitp-backend/storage/*.key
/aitp-backend/public/storage
/aitp-backend/vendor/
/aitp-backend/.phpunit.result.cache
